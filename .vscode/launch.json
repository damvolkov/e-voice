{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "e-voice",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/e_voice/main.py",
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src",
                "DEBUG": "True",
                "ENVIRONMENT": "DEV",
                "WHISPER_DEVICE": "cuda",
                "WHISPER_COMPUTE_TYPE": "float16",
                "WHISPER_MODEL": "mobiuslabsgmbh/faster-whisper-large-v3-turbo"
            },
            "justMyCode": false,
            "console": "integratedTerminal"
        },
        {
            "name": "e-voice (CPU)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/e_voice/main.py",
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src",
                "DEBUG": "True",
                "ENVIRONMENT": "DEV",
                "WHISPER_DEVICE": "cpu",
                "WHISPER_COMPUTE_TYPE": "int8",
                "WHISPER_MODEL": "mobiuslabsgmbh/faster-whisper-large-v3-turbo"
            },
            "justMyCode": false,
            "console": "integratedTerminal"
        }
    ]
}
