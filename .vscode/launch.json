{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "e-voice",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/e_voice/main.py",
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src",
                "LD_LIBRARY_PATH": "${workspaceFolder}/.venv/lib/python3.12/site-packages/nvidia/cublas/lib:${workspaceFolder}/.venv/lib/python3.12/site-packages/nvidia/cudnn/lib"
            },
            "justMyCode": false,
            "console": "integratedTerminal"
        }
    ]
}
